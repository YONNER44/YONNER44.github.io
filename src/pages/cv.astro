              <div class="mb-8">
                <h3 class="text-xl font-bold text-[rgb(var(--accent-dark))] mb-2">Desarrollador Full-Stack / Front-End</h3>
                <p class="text-[rgb(var(--gray))] text-sm mb-4">Junio 2024 - Enero 2026</p>
                <p class="leading-relaxed mb-4">
