---
import PageLayout from "@layouts/PageLayout.astro"
import Container from "@components/Container.astro"
---

<PageLayout title="Curriculum Vitae" description="Tecnologo en Analisis y Desarrollo de Software">
  <Container size="2xl">
    <div class="animate max-w-7xl mx-auto py-8 mt-16">
      <div class="bg-[rgb(var(--gray-999-basis))] rounded-2xl p-10 shadow-2xl">
        <div class="relative mb-12">
          <a href="/blog" class="absolute top-0 left-0 inline-flex items-center gap-2 px-5 py-2.5 bg-black dark:bg-white rounded-lg hover:shadow-lg hover:scale-105 hover:-translate-x-1 transition-all duration-300 z-10 font-semibold no-underline text-white dark:text-black group">
            <svg class="w-5 h-5 stroke-[2.5] group-hover:-translate-x-1 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
            Volver
          </a>
          <a href="/documents/CV-YONNER-VARGAS-BERNATE.pdf" download class="absolute top-0 right-0 inline-flex items-center gap-2 px-5 py-2.5 border bg-black dark:bg-white text-white dark:text-black rounded-lg hover:shadow-lg hover:scale-105 hover:translate-x-1 transition-all duration-300 z-10 font-semibold no-underline group">
            <svg class="w-5 h-5 stroke-[2.2]" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v11m0 0l4-4m-4 4l-4-4M5 21h14"/>
