                <li class="leading-relaxed"><strong>Internship:</strong> plataforma para reservas de alojamientos, transportes y pasantias para estudiantes.</li>
              </ul>
            </section>

            <section>
              <h2 class="flex items-center gap-3 text-2xl font-bold text-[rgb(var(--accent-dark))] mb-5">Identificacion</h2>
              <p class="leading-relaxed"><strong>YONNER VARGAS BERNATE</strong></p>
              <p class="leading-relaxed"><strong>CC:</strong> 1006155207</p>
            </section>
          </div>
        </div>
      </div>
    </div>
  </Container>
</PageLayout>
