---
import PageLayout from "@layouts/PageLayout.astro"
import Container from "@components/Container.astro"
import { Image } from "astro:assets"
import logoPharmaAI from "@assets/logoautomatizacion.png"

// Importa tus imágenes
import img1 from "@assets/intenrship/img1.png";
import img2 from "@assets/intenrship/img2.png";
import img3 from "@assets/intenrship/img3.png";
import img4 from "@assets/intenrship/img4.png";
import Carrousel from "@components/Carrousel.tsx";
const images = [img1, img2, img3, img4];
---

<PageLayout title="Automatización WhatsApp" description="Sistema de recolección automática de precios de medicamentos vía WhatsApp Web con IA">
  <Container size="2xl">
    <div class="animate max-w-5xl mx-auto py-8 mt-16">
      
      <!-- Card Principal del Proyecto -->
      <div class="bg-white dark:bg-[rgb(var(--gray-999))] rounded-3xl p-4 sm:p-8 md:p-12 shadow-2xl border dark:border-[rgb(var(--gray-800))]">
        
        <!-- Header con botón volver -->
        <div class="mb-8 md:mb-12">
          <div class="text-center">
            <!-- Logo del Proyecto -->
            <div class="flex flex-col items-center justify-center gap-4 md:gap-6 mb-6">
              <div class="w-24 h-24 md:w-32 md:h-32 bg-white dark:bg-white rounded-3xl flex items-center justify-center shadow-lg p-3 md:p-4">
                <Image src={logoPharmaAI} alt="PharmaAI Logo" class="w-full h-full object-contain" />
              </div>
            </div>
            <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black mb-3 md:mb-4 text-[rgb(var(--gray-dark))] dark:text-white tracking-tight drop-shadow-lg">Automatización WhatsApp</h1>
            <p class="text-lg md:text-xl font-medium text-[rgb(var(--gray-dark))] mb-4">Sistema de recolección automática de precios de medicamentos vía WhatsApp Web</p>
            <div class="flex items-center justify-center gap-2 text-sm text-[rgb(var(--gray))]">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span>Marzo 2026 - Actualidad</span>
            </div>
          </div>
        </div>

        <!-- Contenido Principal en Cards -->
        <div class="space-y-6">
          
          <!-- Descripción -->
          <section class="bg-[rgb(var(--gray-light))] dark:bg-[rgb(var(--gray-800))] rounded-2xl p-6 md:p-8 shadow-md">
            <h2 class="text-2xl font-bold text-[rgb(var(--gray-dark))] dark:text-white mb-4">Descripción del Proyecto</h2>
            <p class="leading-relaxed text-lg text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))]">
              Sistema de recolección automática de precios de medicamentos vía WhatsApp Web. Los proveedores envían sus listas de precios (texto o imagen) 
              y el sistema las extrae con IA, las organiza y las sincroniza automáticamente en Google Sheets y Excel. Arquitectura containerizada con Docker Compose, 
              backend FastAPI, frontend React y sincronización en tiempo real.
            </p>
          </section>

          <!-- Asociación -->
          <section class="bg-[rgb(var(--accent-light)/0.15)] dark:bg-[rgb(var(--accent-dark)/0.2)] rounded-2xl p-6 md:p-8 shadow-md">
            <div class="flex items-center gap-3 mb-3">
              <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] dark:text-[rgb(var(--accent-light))]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              <h3 class="text-xl font-bold text-[rgb(var(--gray-dark))] dark:text-white">Asociación</h3>
            </div>
            <p class="leading-relaxed text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))]">Proyecto desarrollado en colaboración con <strong>Disruptive Information Technologies</strong></p>
          </section>

          <!-- Características Principales -->
          <section class="bg-[rgb(var(--gray-light))] dark:bg-[rgb(var(--gray-800))] rounded-2xl p-6 md:p-8 shadow-md">
            <h2 class="text-2xl font-bold text-[rgb(var(--gray-dark))] dark:text-white mb-5">Características Principales</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="flex gap-3">
                <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  <h3 class="font-semibold text-[rgb(var(--gray-dark))] dark:text-white mb-1">OCR + Extracción con IA</h3>
                  <p class="text-sm text-[rgb(var(--gray-dark))]">OCR de imágenes y extracción de precios con OpenAI (GPT-4o-mini)</p>
                </div>
              </div>
              <div class="flex gap-3">
                <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  <h3 class="font-semibold text-[rgb(var(--gray-dark))] dark:text-white mb-1">Sincronización Google Sheets</h3>
                  <p class="text-sm text-[rgb(var(--gray-dark))]">Integración en tiempo real con Google Sheets API y descargas a Excel</p>
                </div>
              </div>
              <div class="flex gap-3">
                <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  <h3 class="font-semibold text-[rgb(var(--gray-dark))] dark:text-white mb-1">Fuzzy Matching</h3>
                  <p class="text-sm text-[rgb(var(--gray-dark))]">Matching inteligente de medicamentos con reconocimiento de similitudes</p>
                </div>
              </div>
              <div class="flex gap-3">
                <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  <h3 class="font-semibold text-[rgb(var(--gray-dark))] dark:text-white mb-1">Docker Compose</h3>
                  <p class="text-sm text-[rgb(var(--gray-dark))]">Arquitectura containerizada con PostgreSQL, FastAPI, React + nginx y Node.js</p>
                </div>
              </div>
              <div class="flex gap-3">
                <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] flex-shrink-0 mt-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <div>
                  <h3 class="font-semibold text-[rgb(var(--gray-dark))] dark:text-white mb-1">Gestor de Proveedores</h3>
                  <p class="text-sm text-[rgb(var(--gray-dark))]">Gestión automática de números de WhatsApp y comunicación bidireccional</p>
                </div>
              </div>
            </div>
          </section>

          <!-- Stack Tecnológico -->
          <section class="bg-[rgb(var(--gray-light))] dark:bg-[rgb(var(--gray-800))] rounded-2xl p-6 md:p-8 shadow-md">
            <h2 class="text-2xl font-bold text-[rgb(var(--gray-dark))] dark:text-white mb-5">Stack Tecnológico</h2>
            <div class="flex flex-wrap gap-3">
              <span class="px-4 py-2 text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))] rounded-full text-sm font-medium">React</span>
              <span class="px-4 py-2 text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))] rounded-full text-sm font-medium">FastAPI</span>
              <span class="px-4 py-2 text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))] rounded-full text-sm font-medium">Python 3.11</span>
              <span class="px-4 py-2 text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))] rounded-full text-sm font-medium">Node.js</span>
              <span class="px-4 py-2 text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))] rounded-full text-sm font-medium">Docker Compose</span>
              <span class="px-4 py-2 text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))] rounded-full text-sm font-medium">PostgreSQL</span>
              <span class="px-4 py-2 text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))] rounded-full text-sm font-medium">OpenAI API</span>
              <span class="px-4 py-2 text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))] rounded-full text-sm font-medium">Google Sheets API</span>
            </div>
          </section>

          <!-- Logros -->
          <section class="bg-[rgb(var(--gray-light))] dark:bg-[rgb(var(--gray-800))] rounded-2xl p-6 md:p-8 shadow-md">
            <h2 class="text-2xl font-bold text-[rgb(var(--gray-dark))] dark:text-white mb-5">Logros Destacados</h2>
            <ul class="space-y-3">
              <li class="flex gap-3 items-start">
                <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] dark:text-[rgb(var(--accent-light))] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="leading-relaxed text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))]">Integración exitosa con WhatsApp Web.js para captura automática de mensajes</span>
              </li>
              <li class="flex gap-3 items-start">
                <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] dark:text-[rgb(var(--accent-light))] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="leading-relaxed text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))]">OCR avanzado y extracción de datos con OpenAI GPT-4o-mini de imágenes de listas de precios</span>
              </li>
              <li class="flex gap-3 items-start">
                <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] dark:text-[rgb(var(--accent-light))] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="leading-relaxed text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))]">Sincronización automática en Google Sheets con colorizaci  ón de precios más bajos</span>
              </li>
              <li class="flex gap-3 items-start">
                <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] dark:text-[rgb(var(--accent-light))] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="leading-relaxed text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))]">Arquitectura Docker Compose escalable con PostgreSQL, FastAPI, React + nginx y Node.js</span>
              </li>
              <li class="flex gap-3 items-start">
                <svg class="w-6 h-6 text-[rgb(var(--accent-dark))] dark:text-[rgb(var(--accent-light))] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="leading-relaxed text-[rgb(var(--gray-dark))] dark:text-[rgb(var(--gray-300))]">Panel administrativo con gestión de proveedores, configuración de credenciales y exportación a Excel</span>
              </li>
            </ul>
          </section>

          <!-- Galería de Imágenes -->
          <section class="bg-[rgb(var(--gray-light))] dark:bg-[rgb(var(--gray-800))] rounded-2xl p-6 md:p-8 shadow-md">
            <h2 class="text-2xl font-bold text-[rgb(var(--gray-dark))] dark:text-white mb-5">
              Galería del Proyecto
            </h2>
            <Carrousel images={images} client:load />
          </section>

          <!-- Botones de Navegación -->
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-6 mt-8 border-t border-black/10 dark:border-white/10">
            <a href="/projects" class="inline-flex items-center gap-2 px-6 py-3 bg-black/5 dark:bg-white/5 hover:bg-black/10 dark:hover:bg-white/10 rounded-lg transition-all duration-300 no-underline font-semibold text-[rgb(var(--gray-dark))] dark:text-white group">
              <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
              </svg>
              Volver a projects
            </a>
            <a href="#" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-black dark:bg-white rounded-lg hover:shadow-lg hover:scale-105 transition-all duration-300 no-underline font-semibold text-white dark:text-black group">
              <svg class="w-5 h-5 group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
              </svg>
              Visitar Sitio
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          </div>

        </div>
      </div>
    </div>
  </Container>
</PageLayout>

