---
import { type CollectionEntry, getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import ArticleTopLayout from "@layouts/ArticleTopLayout.astro"
import ArticleBottomLayout from "@layouts/ArticleBottomLayout.astro"

// Create the static projects pages
export async function getStaticPaths() {
	const projects = await getCollection("projects")
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: project,
	}))
}

// Get the requested project
type Props = CollectionEntry<"projects">
const slug = Astro.params.slug
let project = Astro.props as Props | undefined

if (!project?.data && slug) {
	const projects = await getCollection("projects")
	project = projects.find((entry) => entry.slug === slug)
}

if (!project) {
	return Astro.redirect("/projects")
}

// Redirigir a las vistas personalizadas
const projectRoutes: Record<string, string> = {
	"project-1": "/projects/internship",
	"project-2": "/projects/dsx",
	"project-3": "/projects/div-manager",
	"project-4": "/projects/pharmaai",
}

const hasCustomRoute = projectRoutes[project.slug]

const { title, summary } = project.data
const redirectUrl = hasCustomRoute ? projectRoutes[project.slug] : null
---

<PageLayout title={title} description={summary}>
  {hasCustomRoute && (
    <script is:inline set:html={`window.location.replace("${redirectUrl}")`}></script>
  )}
  {!hasCustomRoute && (
  <TopLayout>
    <div class="animate">
      <ArticleTopLayout entry={project} />
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <ArticleBottomLayout entry={project} />
    </div>
  </BottomLayout>
  )}
</PageLayout>
